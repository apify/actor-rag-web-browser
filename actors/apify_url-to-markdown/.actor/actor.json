{
    "actorSpecification": 1,
    "name": "url-to-markdown",
    "title": "URL to Markdown",
    "description": "An Apify Actor that takes a URL as input and returns the content of the page in Markdown format.",
    "version": "1.0",
    "input": "./input_schema.json",
    "defaultMemoryMbytes": 1024,
    "minMemoryMbytes": 256,
    "maxMemoryMbytes": 32768,
    "dockerContextDir": "../../..",
    "changelog": "../CHANGELOG.md",
    "dockerfile": "../../../Dockerfile",
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "title": "URL to Markdown",
            "description": "",
            "views": {
                "overview": {
                    "title": "Overview",
                    "description": "",
                    "transformation": {
                        "flatten": ["metadata", "searchResult"],
                        "fields": [
                            "metadata.url",
                            "markdown"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "metadata.url": {
                                "label": "URL",
                                "format": "link"
                            },
                            "text": {
                                "label": "Markdown",
                                "format": "text"
                            }
                        }
                    }
                }
            }
        }
    }
}
